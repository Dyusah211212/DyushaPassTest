local function createSlider(p, n, mn, mx, dv, cb)
    local f = Instance.new("Frame")
    f.Size = UDim2.new(1, 0, 0, 54)
    f.BackgroundTransparency = 1
    f.BorderSizePixel = 0
    f.Parent = p
    local lb = Instance.new("TextLabel", f)
    lb.Size = UDim2.new(1, 0, 0, 18)
    lb.BackgroundTransparency = 1
    lb.Text = n
    lb.TextColor3 = V.text
    lb.TextSize = 12 * scale
    lb.Font = Enum.Font.Gotham
    lb.TextXAlignment = Enum.TextXAlignment.Left
    local vl = Instance.new("TextLabel", f)
    vl.Size = UDim2.new(0, 55, 0, 18)
    vl.Position = UDim2.new(1, -55, 0, 0)
    vl.BackgroundTransparency = 1
    vl.Text = tostring(dv)
    vl.TextColor3 = V.textDim
    vl.TextSize = 12 * scale
    vl.Font = Enum.Font.GothamBold
    vl.TextXAlignment = Enum.TextXAlignment.Right
    local sb = Instance.new("Frame", f)
    sb.Size = UDim2.new(1, 0, 0, 6)
    sb.Position = UDim2.new(0, 0, 0, 26)
    sb.BackgroundColor3 = Color3.fromRGB(40, 40, 55)
    sb.BorderSizePixel = 0
    cornerP(sb, 3)
    local fill = Instance.new("Frame", sb)
    fill.Size = UDim2.new((dv-mn)/(mx-mn), 0, 1, 0)
    fill.BackgroundColor3 = V.accent
    fill.BorderSizePixel = 0
    cornerP(fill, 3)
    local kn = Instance.new("Frame", sb)
    kn.Size = UDim2.new(0, 16, 0, 16)
    kn.Position = UDim2.new((dv-mn)/(mx-mn), -8, 0.5, -8)
    kn.BackgroundColor3 = Color3.fromRGB(240, 240, 255)
    kn.BorderSizePixel = 0
    cornerP(kn, 8)
    local dg = false
    local function up(i)
        local rx = math.clamp((i.Position.X - sb.AbsolutePosition.X) / sb.AbsoluteSize.X, 0, 1)
        local v = math.floor((mn + (mx - mn) * rx) * 100 + 0.5) / 100
        vl.Text = tostring(v)
        fill.Size = UDim2.new(rx, 0, 1, 0)
        kn.Position = UDim2.new(rx, -8, 0.5, -8)
        cb(v)
    end
    sb.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dg = true; up(i) end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if dg and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then up(i) end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dg = false end
    end)
    return f
end

