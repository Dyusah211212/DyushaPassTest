local function createSlider(parent, name, minVal, maxVal, defaultVal, callback)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 54)
    frame.BackgroundTransparency = 1
    frame.BorderSizePixel = 0
    frame.Parent = parent
    local label = Instance.new("TextLabel", frame)
    label.Size = UDim2.new(1, 0, 0, 18)
    label.BackgroundTransparency = 1
    label.Text = name
    label.TextColor3 = V.text
    label.TextSize = 12 * scale
    label.Font = Enum.Font.Gotham
    label.TextXAlignment = Enum.TextXAlignment.Left
    local vl = Instance.new("TextLabel", frame)
    vl.Size = UDim2.new(0, 55, 0, 18)
    vl.Position = UDim2.new(1, -55, 0, 0)
    vl.BackgroundTransparency = 1
    vl.Text = tostring(defaultVal)
    vl.TextColor3 = V.textDim
    vl.TextSize = 12 * scale
    vl.Font = Enum.Font.GothamBold
    vl.TextXAlignment = Enum.TextXAlignment.Right
    local sb = Instance.new("Frame", frame)
    sb.Size = UDim2.new(1, 0, 0, 6)
    sb.Position = UDim2.new(0, 0, 0, 26)
    sb.BackgroundColor3 = Color3.fromRGB(40, 40, 55)
    sb.BorderSizePixel = 0
    cornerP(sb, 3)
    local fill = Instance.new("Frame", sb)
    fill.Size = UDim2.new((defaultVal-minVal)/(maxVal-minVal), 0, 1, 0)
    fill.BackgroundColor3 = V.accent
    fill.BorderSizePixel = 0
    cornerP(fill, 3)
    local knob = Instance.new("Frame", sb)
    knob.Size = UDim2.new(0, 16, 0, 16)
    knob.Position = UDim2.new((defaultVal-minVal)/(maxVal-minVal), -8, 0.5, -8)
    knob.BackgroundColor3 = Color3.fromRGB(240, 240, 255)
    knob.BorderSizePixel = 0
    cornerP(knob, 8)
    local dragging = false
    local function upd(input)
        local rx = math.clamp((input.Position.X - sb.AbsolutePosition.X) / sb.AbsoluteSize.X, 0, 1)
        local val = math.floor((minVal + (maxVal - minVal) * rx) * 100 + 0.5) / 100
        vl.Text = tostring(val); fill.Size = UDim2.new(rx, 0, 1, 0); knob.Position = UDim2.new(rx, -8, 0.5, -8); callback(val)
    end
    sb.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = true; upd(input) end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then upd(input) end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
    end)
    return frame
end

local function createToggle(parent, name, defaultVal, callback, desc)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, desc and 56 or 40)
    frame.BackgroundTransparency = 1
    frame.BorderSizePixel = 0
    frame.Parent = parent
    local label = Instance.new("TextLabel", frame)
    label.Size = UDim2.new(1, -50, 0, 20)
    label.Position = UDim2.new(0, 0, 0, desc and 4 or 10)
    label.BackgroundTransparency = 1
    label.Text = name
    label.TextColor3 = V.text
    label.TextSize = 12 * scale
    label.Font = Enum.Font.Gotham
    label.TextXAlignment = Enum.TextXAlignment.Left
    if desc then
        local dl = Instance.new("TextLabel", frame)
        dl.Size = UDim2.new(1, -50, 0, 16)
        dl.Position = UDim2.new(0, 0, 0, 26)
        dl.BackgroundTransparency = 1
        dl.Text = desc
        dl.TextColor3 = Color3.fromRGB(130, 125, 165)
        dl.TextSize = 10 * scale
        dl.Font = Enum.Font.Gotham
        dl.TextXAlignment = Enum.TextXAlignment.Left
    end
    local tb = Instance.new("Frame", frame)
    tb.Size = UDim2.new(0, 40, 0, 22)
    tb.Position = UDim2.new(1, -40, 0, desc and 4 or 10)
    tb.BackgroundColor3 = defaultVal and V.accent or Color3.fromRGB(45, 45, 55)
    tb.BorderSizePixel = 0
    cornerP(tb, 11)
    local tk = Instance.new("Frame", tb)
    tk.Size = UDim2.new(0, 18, 0, 18)
    tk.Position = defaultVal and UDim2.new(1, -20, 0.5, -9) or UDim2.new(0, 2, 0.5, -9)
    tk.BackgroundColor3 = Color3.fromRGB(240, 240, 255)
    tk.BorderSizePixel = 0
    cornerP(tk, 9)
    local active = defaultVal
    tb.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            active = not active
            TweenService:Create(tb, TweenInfo.new(0.3, Enum.EasingStyle.Exponential), {BackgroundColor3 = active and V.accent or Color3.fromRGB(45,45,55)}):Play()
            tk:TweenPosition(active and UDim2.new(1,-20,0.5,-9) or UDim2.new(0,2,0.5,-9), "Out", "Exponential", 0.3, true)
            callback(active)
        end
    end)
    return frame
end

local function createButton(parent, name, callback, color)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 0, buttonHeight)
    btn.BackgroundColor3 = color or V.bgSurface
    btn.Text = name
    btn.TextColor3 = V.text
    btn.TextSize = 12 * scale
    btn.Font = Enum.Font.GothamBold
    btn.BorderSizePixel = 0
    btn.Parent = parent
    cornerP(btn, 8)
    btn.MouseButton1Click:Connect(callback)
    btn.MouseEnter:Connect(function() TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = V.bgHover}):Play() end)
    btn.MouseLeave:Connect(function() TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = color or V.bgSurface}):Play() end)
    strokeP(btn, V.strokeLight, 1)
