        autoLoop = task.spawn(function()
            local delay = V.autoSpeed > 0 and (1 / V.autoSpeed) or 0.01
            while autoActive and autoBtn.Parent and screenGui and screenGui.Parent and not destroyed do
                fireFakeSignal(signalType, id)
                task.wait(delay)
            end
            if autoActive then stopAuto() end
        end)
        activeAutoButtons[autoBtn] = {active = true, loop = autoLoop}
    end
    local function stopAuto()
        autoActive = false
        if autoLoop then task.cancel(autoLoop) end
        activeAutoButtons[autoBtn] = nil
        if autoBtn.Parent then
            autoBtn.Text = "Auto"
            autoBtn.TextColor3 = V.text
            TweenService:Create(autoBtn, TweenInfo.new(0.2), {BackgroundColor3 = V.bgSurface}):Play()
        end
    end
    autoBtn.MouseButton1Click:Connect(function() if autoActive then stopAuto() else startAuto() end end)

    local holdStart = nil
    local holdConnection = nil
    local spamLoop = nil
    local isSpamming = false
    local function startSpam()
        if isSpamming then return end
        isSpamming = true
        runBtn.Text = "SPAM"
        runBtn.TextColor3 = V.warning
        spamLoop = task.spawn(function()
            while isSpamming and runBtn.Parent and screenGui and screenGui.Parent and not destroyed do
                fireFakeSignal(signalType, id)
                task.wait(0.08)
            end
            if isSpamming then stopSpam() end
        end)
        activeSpamButtons[runBtn] = {active = true, loop = spamLoop}
    end
    local function stopSpam()
        isSpamming = false
        if spamLoop then task.cancel(spamLoop) end
        activeSpamButtons[runBtn] = nil
        if runBtn.Parent then
            runBtn.Text = "Run"
            runBtn.TextColor3 = V.text
            TweenService:Create(runBtn, TweenInfo.new(0.2), {BackgroundColor3 = V.bgSurface}):Play()
        end
    end

    runBtn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            if isSpamming then return end
            holdStart = tick()
            holdConnection = task.spawn(function()
                while holdStart and (tick() - holdStart) < 2.5 do task.wait(0.1) end
                if holdStart and not isSpamming then startSpam() end
            end)
        end
    end)
    runBtn.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            local held = holdStart and (tick() - holdStart) or 0
            holdStart = nil
            if holdConnection then task.cancel(holdConnection) end
            if isSpamming then stopSpam()
            elseif held < 2.5 then
                fireFakeSignal(signalType, id)
                runBtn.Text = "✓"
                runBtn.TextColor3 = V.success
                task.wait(1)
                if runBtn.Parent then runBtn.Text = "Run"; runBtn.TextColor3 = V.text end
            end
        end
    end)

    stratBtn.MouseButton1Click:Connect(function()
        local acLevel = V.antiCheatLevels[V.currentAntiCheat]
        local topStrat = acLevel.strategies[#acLevel.strategies]
        if strategies[topStrat] then
            strategies[topStrat].execute(id, signalType)
            stratBtn.Text = "✓"
            stratBtn.TextColor3 = V.success
            task.wait(0.5)
            if stratBtn.Parent then stratBtn.Text = "⚡"; stratBtn.TextColor3 = V.warning end
        end
    end)

    entry.AncestryChanged:Connect(function()
        if not entry.Parent then
            if autoActive then stopAuto() end
            if isSpamming then stopSpam() end
            for i, e in ipairs(entries) do
                if e.frame == entry then table.remove(entries, i); break end
            end
            eventCount = math.max(0, eventCount - 1)
            if countLabel and countLabel.Parent then
                countLabel.Text = eventCount .. (eventCount == 1 and " event" or " events")
            end
        end
    end)

    eventCount = eventCount + 1
    countLabel.Text = eventCount .. (eventCount == 1 and " event" or " events")
    table.insert(entries, {frame = entry, gpid = id, sigtype = signalType})
end

