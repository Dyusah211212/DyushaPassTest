local function fireFakeSignal(st, id)
    suppressCounter = suppressCounter + 1
    pcall(function()
        if st == "Product" then MarketplaceService:SignalPromptProductPurchaseFinished(player.UserId, id, true)
        elseif st == "Gamepass" then MarketplaceService:SignalPromptGamePassPurchaseFinished(player, id, true)
        elseif st == "Bulk" then MarketplaceService:SignalPromptBulkPurchaseFinished(player.UserId, id, true)
        elseif st == "Purchase" then MarketplaceService:SignalPromptPurchaseFinished(player.UserId, id, true)
        elseif st == "Bundle" then MarketplaceService:SignalPromptBundlePurchaseFinished(player, id, true) end
    end)
    task.wait(0.01)
    suppressCounter = suppressCounter - 1
end

