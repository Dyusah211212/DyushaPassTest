                        local h = p.Character.Humanoid
                        local hr = p.Character:FindFirstChild("HumanoidRootPart")
                        if h.Health > 0 and hr then
                            local myPos = player.Character and player.Character:FindFirstChild("HumanoidRootPart") and player.Character.HumanoidRootPart.Position or Vector3.zero
                            local d = (hr.Position - myPos).Magnitude
                            if d < 20 then
                                h:TakeDamage(50)
                            end
                        end
                    end
                end
                task.wait(0.5)
            end
        end)
    end
end)

-- Refresh, Godmode, Ghost
local function refreshF()
    local ch = player.Character; if not ch then return end
    local hr = ch:FindFirstChild("HumanoidRootPart"); local sv = hr and hr.CFrame or nil
    local hm = ch:FindFirstChild("Humanoid"); if hm then hm:ChangeState(Enum.HumanoidStateType.Dead) end
    ch:ClearAllChildren()
    local d = Instance.new("Model", workspace); player.Character = d; player.Character = ch; d:Destroy()
    if sv then
        local nc = player.CharacterAdded:Wait(); local nh = nc:WaitForChild("HumanoidRootPart", 5)
        if nh then task.delay(0.1, function() nh.CFrame = sv end) end
    end
end

local function godmodeF()
    local ch = player.Character; if not ch then return end
    local hm = ch:FindFirstChild("Humanoid"); if not hm then return end
    local nh = hm:Clone(); nh.Parent = ch
    nh:SetStateEnabled(Enum.HumanoidStateType.Dead, false); nh:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
    nh:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false); nh.BreakJointsOnDeath = false
    nh.MaxHealth = math.huge; nh.Health = math.huge; hm:Destroy()
    pcall(function() workspace.CurrentCamera.CameraSubject = nh end)
    local an = ch:FindFirstChild("Animate"); if an then an.Disabled = true; an.Disabled = false end
end

local gc = nil
local function ghostF()
    if gc then if gc.Parent then gc:Destroy() end; gc = nil
        if player.Character then pcall(function() workspace.CurrentCamera.CameraSubject = player.Character:FindFirstChild("Humanoid") end) end
        return
    end
    local ch = player.Character; if not ch then return end
    ch.Archivable = true; gc = ch:Clone(); ch.Archivable = false
    local hm = gc:FindFirstChild("Humanoid"); if hm then hm.DisplayName = "👻" end
    for _, p in pairs(gc:GetDescendants()) do if p:IsA("BasePart") then p.Transparency = 0.5 end end
    gc.Parent = workspace; player.Character = gc
    if hm then pcall(function() workspace.CurrentCamera.CameraSubject = hm end) end
end

