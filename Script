function scanAllGamepasses()
    allGamepasses = {}
    
    local success, response = pcall(function()
        return game:HttpGet("https://games.roblox.com/v1/games/" .. game.PlaceId .. "/game-passes?limit=100&sortOrder=Asc")
    end)
    
    if not success or not response or response == "" then return allGamepasses end
    
    local success2, data = pcall(function()
        return HttpService:JSONDecode(response)
    end)
    
    if not success2 or not data or not data.data then return allGamepasses end
    
    for _, gp in ipairs(data.data) do
        if not scannedIds[gp.id] then
            scannedIds[gp.id] = true
            table.insert(allGamepasses, {id = gp.id, name = gp.name or "Unknown", price = gp.price or 0})
        end
    end
    
    return allGamepasses
end

