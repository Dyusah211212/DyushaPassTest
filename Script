local jobConnections = {}
local function onJobChange(jobName, callback)
    if not jobConnections[jobName] then jobConnections[jobName] = {} end
    table.insert(jobConnections[jobName], callback)
end

local function setJobActive(jobName, active, value)
    if jobs[jobName] then
        jobs[jobName].active = active
        if value ~= nil then jobs[jobName].value = value end
        if jobConnections[jobName] then
            for _, cb in ipairs(jobConnections[jobName]) do
                task.spawn(cb, jobs[jobName])
            end
        end
    end
end

local function setJobValue(jobName, value)
    if jobs[jobName] then
        jobs[jobName].value = value
        if jobConnections[jobName] then
            for _, cb in ipairs(jobConnections[jobName]) do
                task.spawn(cb, jobs[jobName])
            end
        end
    end
end

