    local char = player.Character; if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart"); local saved = hrp and hrp.CFrame or nil
    local hum = char:FindFirstChild("Humanoid"); if hum then hum:ChangeState(Enum.HumanoidStateType.Dead) end
    char:ClearAllChildren()
    local dummy = Instance.new("Model", workspace); player.Character = dummy; player.Character = char; dummy:Destroy()
    if saved then
        local nc = player.CharacterAdded:Wait(); local nh = nc:WaitForChild("HumanoidRootPart", 5)
        if nh then task.delay(0.1, function() nh.CFrame = saved end) end
    end
end

local function godmode()
    local char = player.Character; if not char then return end
    local hum = char:FindFirstChild("Humanoid"); if not hum then return end
    local nh = hum:Clone(); nh.Parent = char
    nh:SetStateEnabled(Enum.HumanoidStateType.Dead, false); nh:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
    nh:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false); nh.BreakJointsOnDeath = false
    nh.MaxHealth = math.huge; nh.Health = math.huge; hum:Destroy()
    pcall(function() workspace.CurrentCamera.CameraSubject = nh end)
    local an = char:FindFirstChild("Animate"); if an then an.Disabled = true; an.Disabled = false end
end

local ghostChar = nil
local function toggleGhost()
    if ghostChar then
        if ghostChar.Parent then ghostChar:Destroy() end; ghostChar = nil
        if player.Character then pcall(function() workspace.CurrentCamera.CameraSubject = player.Character:FindFirstChild("Humanoid") end) end
        return
    end
    local char = player.Character; if not char then return end
    char.Archivable = true; ghostChar = char:Clone(); char.Archivable = false
    local hum = ghostChar:FindFirstChild("Humanoid"); if hum then hum.DisplayName = "👻" end
    for _, p in pairs(ghostChar:GetDescendants()) do if p:IsA("BasePart") then p.Transparency = 0.5 end end
    ghostChar.Parent = workspace; player.Character = ghostChar
    if hum then pcall(function() workspace.CurrentCamera.CameraSubject = hum end) end
end

