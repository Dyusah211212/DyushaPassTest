local jc = {}
local function onJob(n, cb)
    if not jc[n] then jc[n] = {} end
    table.insert(jc[n], cb)
end

local function setJA(n, b, v)
    if jobs[n] then
        jobs[n].a = b
        if v ~= nil then jobs[n].v = v end
        if jc[n] then for _, cb in ipairs(jc[n]) do task.spawn(cb, jobs[n]) end end
    end
end

local function setJV(n, v)
    if jobs[n] then
        jobs[n].v = v
        if jc[n] then for _, cb in ipairs(jc[n]) do task.spawn(cb, jobs[n]) end end
    end
end

